WEBHOOK_SECRET=094d8079323e5a288659a8cfa535917b1ae95c07135c409aeaa6e7c1a0154ac1

# ====================
# Server
# ====================
PORT=3000
NODE_ENV=production
FARM_LAT=10.7769
FARM_LON=106.7009
TZ=Asia/Ho_Chi_Minh

# ====================
# Database
# ====================
DB_PATH=/data/ecosyntech.db

# ====================
# MQTT (Vietnam ESP32 devices)
# ====================
MQTT_BROKER_URL=wss://broker.hivemq.com:8884/mqtt
MQTT_USERNAME=
MQTT_PASSWORD=

# ====================
# AI/ML Bootstrap (TFLite default ON, ONNX optional)
# ====================
AI_SMALL_MODEL=1
AI_LARGE_MODEL=0
AI_CONFIDENCE_THRESHOLD=0.6
AI_ENGINE_ENABLED=true

# ====================
# Device Provisioning
# ====================
MAX_DEVICES=100
DEVICE_HEARTBEAT_INTERVAL=60

# ====================
# Security
# ====================
CORS_ORIGIN=*
LOG_LEVEL=info