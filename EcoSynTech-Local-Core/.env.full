# ═══════════════════════════════════════════════════════════════════════
# EcoSynTech Local Core V3.0 - Environment Template
# 
# CÁCH SỬ DỤNG:
# 1. Copy thành .env: copy .env.example .env
# 2. Điền các giá trị cần thiết
# 3. Các trường để trống sẽ tự động sử dụng mặc định
# ═══════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# 🔐 BẢO MẬT - QUAN TRỌNG!
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=CHANGE_ME_NOW

# ═══════════════════════════════════════════════════════════════════════
# 🖥️ SERVER CONFIG
# ═══════════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════
# 🤖 AI CONFIG (Tùy chọn)
# ═══════════════════════════════════════════════════════════════
# AI Provider: deepseek | ollama | openai | gemini | template
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ═══════════════════════════════════════════════════════════════════════
# 📱 NOTIFICATIONS (Tùy chọn)
# ═══════════════════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=

# ═══════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DB_TYPE=sqlite
DB_PATH=./data/ecosyntech.db

# ═══════════════════════════════════════════════════════════════════════
# 🌤️ WEATHER (Miễn phí - Open-Meteo)
# ═══════════════════════════════════════════════════════════════
FARM_LAT=10.7769
FARM_LON=106.7009

# ═══════════════════════════════════════════════════════���═══════════════
# 🔒 SECURITY
# ═══════════════════════════════════════════════════════════════
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ═══════════════════════════════════════════════════════════════════════
# 💾 BACKUP
# ═══════════════════════════════════════════════════════════════
AUTO_BACKUP_ENABLED=false
BACKUP_INTERVAL=daily

# ═══════════════════════════════════════════════════════════════════════
# 📝 LOGGING
# ═══════════════════════════════════════════════════════════════
LOG_LEVEL=info