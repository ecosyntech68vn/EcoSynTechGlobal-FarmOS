# ═══════════════════════════════════════════════════════════════════════
# EcoSynTech Local Core V3.0 - BASE Environment
# Gói cơ bản - Đủ tính năng cho người mới bắt đầu
# ═══════════════════════════════════════════════════════════════════════════════

# 🔐 BẢO MẬT
JWT_SECRET=base-secret-2024
JWT_EXPIRY=86400

# 🖥️ SERVER
PORT=3000
NODE_ENV=production

# 🤖 AI
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 📱 NOTIFICATIONS
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ZALO_APP_ID=

# 📊 MONITORING
METRICS_ENABLED=true

# 🔒 SECURITY
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 💾 BACKUP TỰ ĐỘNG
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL=daily
BACKUP_RETENTION=7

# 📈 AI FEATURES
AI_ENGINE_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.6

# 🌤️ WEATHER
FARM_LAT=10.7769
FARM_LON=106.7009

# 💧 WATER OPTIMIZATION
WATER_OPTIMIZATION_ENABLED=true
WATER_MIN_MOISTURE=30
WATER_MAX_MOISTURE=70

# 📱 MULTI-USER
MAX_USERS_UNLIMITED=false
MAX_USERS=10

# 📊 DATABASE
DB_TYPE=sqlite
DB_PATH=./data/ecosyntech.db

# 🧹 MAINTENANCE
LOG_LEVEL=info