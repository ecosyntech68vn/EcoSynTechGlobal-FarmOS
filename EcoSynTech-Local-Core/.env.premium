# ═══════════════════════════════════════════════════════════════════════
# EcoSynTech Local Core V3.0 - PREMIUM Environment
# Gói cao cấp nhất - Đầy đủ mọi tính năng quản trị
# ═══════════════════════════════════════════════════════════════════════

# 🔐 BẢO MẬT
JWT_SECRET=premium-secret-key-2024
JWT_EXPIRY=86400

# 🖥️ SERVER
PORT=3000
NODE_ENV=production

# 🤖 AI - Đầy đủ providers
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OPENAI_API_KEY=
GEMINI_API_KEY=

# 📱 NOTIFICATIONS - Đầy đủ
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ZALO_APP_ID=
ZALO_APP_SECRET=

# 💳 PAYMENT GATEWAYS
VNPAY_TMNCODE=
MOMO_SECRET_KEY=
SEPAY_PARTNER_ID=

# 📊 ANALYTICS & MONITORING
METRICS_ENABLED=true
INFLUXDB_URL=
INFLUXDB_TOKEN=

# 🔒 SECURITY NÂNG CAO
CORS_ORIGIN=*
RATE_LIMIT_WINDOW_MS=600000
RATE_LIMIT_MAX_REQUESTS=1000
SESSION_TIMEOUT=7200
HMAC_SECRET=premium-hmac-secret

# 💾 BACKUP AUTOMATION
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL=hourly
BACKUP_RETENTION=30
BACKUP_CLOUD_ENABLED=true

# 📈 ADVANCED FEATURES
AI_ENGINE_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.5
BLOCKCHAIN_ENABLED=true
WEBLOCAL_WEBAPP_URL=

# 🌤️ WEATHER API
FARM_LAT=10.7769
FARM_LON=106.7009

# 💧 WATER OPTIMIZATION
WATER_OPTIMIZATION_ENABLED=true
WATER_MIN_MOISTURE=25
WATER_MAX_MOISTURE=75
WATER_CHECK_INTERVAL=180000

# 📱 MULTI-USER
MAX_USERS_UNLIMITED=true
MULTI_TENANT_ENABLED=true

# 📊 DATABASE
DB_TYPE=sqlite
DB_PATH=./data/ecosyntech.db
PG_HOST=localhost

# 🧹 MAINTENANCE
LOG_LEVEL=debug
OPS_SCHEDULER_INTERVAL=60000